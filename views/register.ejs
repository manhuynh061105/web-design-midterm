<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container">
  <div class="row justify-content-center align-items-center" style="min-height:60vh;">
    <div class="col-md-4">

      <div class="card shadow rounded-4 p-4">
        <h3 class="text-center mb-4">📝 Đăng ký</h3>

        <form method="POST" action="/register">
          <div class="mb-3">
            <label class="form-label">Username</label>
            <input name="username" class="form-control" placeholder="Nhập username" required>
          </div>

          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Nhập password" required>
          </div>

          <button class="btn btn-success w-100">Đăng ký</button>
        </form>

        <div class="text-center mt-3">
          <small>Đã có tài khoản?</small><br>
          <a href="/login" class="btn btn-outline-primary btn-sm mt-2">Đăng nhập</a>
        </div>

      </div>

    </div>
  </div>
</div>

<%- include('partials/footer') %>