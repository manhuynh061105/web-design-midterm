<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container mt-5">
  <div class="card p-4 shadow rounded-4">


    <div class="row">
      <div class="col-md-6">
        <img src="<%= product.image ? product.image : '/img/products/product-1.jpg' %>" class="img-fluid" alt="">
      </div>
      <div class="col-md-6">
        <h2><%= product.name %></h2>

        <p><strong>Giá:</strong> ₫<%= product.price %></p>

        <p><strong>Danh mục:</strong> <%= product.category %></p>

        <p><strong>Mô tả:</strong></p>
        <p><%= product.description || 'Không có mô tả' %></p>

        <p><strong>Tồn kho:</strong> <%= typeof product.stock !== 'undefined' ? product.stock : 0 %></p>
      </div>
    </div>

    <a href="/" class="btn btn-secondary mt-3">⬅ Quay lại</a>

  </div>
</div>

<%- include('partials/footer') %>